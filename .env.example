SERVER_PORT=8080

LOGGING_LEVEL=info

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=online_course
POSTGRES_SSLMODE=disable
POSTGRES_MAX_OPEN_CONNS=30
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_CONN_MAX_IDLE_MIN=15
POSTGRES_CONN_MAX_LIFETIME_MIN=60
REDIS_ADDR=localhost:6379
REDIS_DB=0

JWT_ISSUER=online-course
JWT_ACCESS_SECRET=replace-me-access
JWT_REFRESH_SECRET=replace-me-refresh
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_MIN=10080

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=course-resources
# 可选；浏览器访问对象直链的基址（含 http/https）。容器内 endpoint 为 minio:9000 时通常填 http://localhost:9000
MINIO_PUBLIC_BASE_URL=http://localhost:9000
# 开发 true 时自动设置桶匿名可读，避免直链 AccessDenied；生产务必 false
MINIO_PUBLIC_READ=false
